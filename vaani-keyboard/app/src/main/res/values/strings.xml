    <string name="setup_enable_title">Enable Vaani Keyboard</string>
    <string name="setup_enable_instructions">To use Vaani for typing:\n\n1. Open your phone\'s Settings\n2. Go to Language &amp; Input\n3. Select Keyboards / On-screen keyboard\n4. Enable "Vaani"\n5. Return here and tap Next</string>
