<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vaani_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/vaani_text"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Language Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/settings_language_label"
            android:textColor="@color/vaani_text"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btn_settings_lang_hi"
            style="@style/Widget.Vaani.LangOption"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/subtype_hindi"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_settings_lang_mr"
            style="@style/Widget.Vaani.LangOption"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="@string/subtype_marathi"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_settings_lang_en"
            style="@style/Widget.Vaani.LangOption"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="@string/subtype_hinglish"
            android:textSize="15sp" />

        <!-- Keyboard Height Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Keyboard Height"
            android:textColor="@color/vaani_text"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_keyboard_height_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="100%"
                android:textColor="@color/vaani_text"
                android:textSize="14sp"
                android:minWidth="48dp" />

            <SeekBar
                android:id="@+id/seek_keyboard_height"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:max="80"
                android:progress="40"
                android:progressTint="@color/vaani_accent" />

        </LinearLayout>

        <!-- About Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/settings_about_label"
            android:textColor="@color/vaani_text"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_about_text"
            android:textColor="@color/vaani_text_muted"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

</ScrollView>
