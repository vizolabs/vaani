<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_switch_title"
        android:textColor="@color/vaani_text"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/setup_switch_instructions"
        android:textColor="@color/vaani_text_muted"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

    <Button
        android:id="@+id/btn_open_default_keyboard_settings"
        style="@style/Widget.Vaani.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:minHeight="48dp"
        android:text="@string/setup_switch_open_settings"
        android:textSize="15sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/setup_switch_return_hint"
        android:textColor="@color/vaani_text_dim"
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>
