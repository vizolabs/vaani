><string name="setup_enable_open_settings">Open Keyboard Settings</string><string name="setup_enable_return_hint">Return to this screen after enabling</string><string name="settings_title">Settings</string><string name="settings_language_label">Input Language</string><string name="settings_about_label">About Vaani</string><string name="settings_about_text">Vaani converts your native language text and voice into grammatically correct English. Everything runs entirely on your device — no internet needed, no data leaves your phone.\n\nVersion 1.0.0</string><string name="settings_lang_saved">Language saved</string><string name="setup_switch_title">Set Vaani as Default Keyboard</string><string name="setup_switch_instructions">To make Vaani your main keyboard:\n\n1. Open your phone\'s Settings\n2. Go to Language &amp; Input\n3. Tap Default Keyboard\n4. Select "Vaani"\n5. Return here and tap Next</string><string name="setup_switch_open_settings">Open Keyboard Settings</string><string name="setup_language_title">Choose Your Input Language</string><string name="setup_language_subtitle">Select the language you\'ll type in. Vaani will transliterate and translate it to English.</string><string name="setup_ready_title">You\'re All Set!</string><string name="setup_ready_tutorial">Type in Hindi, Marathi, or Hinglish\nVaani transliterates to Devanagari\nthen translates to English</string><string name="setup_ready_tip">Try the voice input button on the keyboard</string><string name="voice_listening">Listening...</string><string name="voice_error">Voice input error: %s</string><string name="voice_no_speech">No speech detected. Try again.</string><string name="voice_unavailable">Speech recognition not available on this device</string><string name="kb_symbol_toggle">12#</string><string name="kb_abc_toggle">ABC</string></file><file name="vaani_ime" path="/Users/vixux/2026 Vizolab FACTORY/Vaani/vaani-keyboard/app/src/main/res/xml/vaani_ime.xml" qualifiers="" type="xml"/><file name="ic_la