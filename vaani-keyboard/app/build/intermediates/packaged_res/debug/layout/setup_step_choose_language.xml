<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_language_title"
        android:textColor="@color/vaani_text"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/setup_language_subtitle"
        android:textColor="@color/vaani_text_muted"
        android:textSize="14sp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_lang_hindi"
        style="@style/Widget.Vaani.LangOption"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:text="@string/subtype_hindi"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_lang_marathi"
        style="@style/Widget.Vaani.LangOption"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="@string/subtype_marathi"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_lang_hinglish"
        style="@style/Widget.Vaani.LangOption"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="@string/subtype_hinglish"
        android:textSize="16sp" />

</LinearLayout>
