    <string name="app_name">Vaani</string>
    <string name="app_tagline">Speak Your Language. We Write English.</string>
    <string name="btn_get_started">Get Started</string>
    <string name="dashboard_ready">✓ Vaani is ready. Translating %s → English.</string>
    <string name="greeting_afternoon">Good Afternoon</string>
    <string name="greeting_evening">Good Evening</string>
    <string name="greeting_morning">Good Morning</string>
