    <style name="Text.Vaani.Body" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/vaani_text</item>
    </style>
    <style name="Text.Vaani.Heading" parent="TextAppearance.AppCompat">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/vaani_text</item>
    </style>
    <style name="Text.Vaani.KeyLabel" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/kb_key_text</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="Text.Vaani.MicLabel" parent="TextAppearance.AppCompat">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/vaani_text_on_accent</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="Text.Vaani.Mono" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/vaani_text_muted</item>
    </style>
    <style name="Text.Vaani.Preview" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/kb_preview_text</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
    </style>
    <style name="Text.Vaani.PreviewEnglish" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/kb_preview_english</item>
    </style>
    <style name="Text.Vaani.Subheading" parent="TextAppearance.AppCompat">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/vaani_text</item>
    </style>
    <style name="Theme.Vaani" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vaani_accent</item>
        <item name="colorPrimaryDark">@color/vaani_dark</item>
        <item name="colorAccent">@color/vaani_accent</item>
        <item name="colorControlNormal">@color/vaani_text_muted</item>
        <item name="colorControlActivated">@color/vaani_accent</item>
        <item name="android:windowBackground">@color/vaani_dark</item>
        <item name="android:statusBarColor">@color/vaani_dark</item>
        <item name="android:navigationBarColor">@color/vaani_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.Vaani.Keyboard" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/kb_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/vaani_dark</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="Theme.Vaani.Splash" parent="Theme.Vaani">
        <item name="android:windowBackground">@color/vaani_dark</item>
    </style>
    <style name="Widget.Vaani.Button" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/vaani_accent</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="Widget.Vaani.Key" parent="Widget.AppCompat.TextView">
        <item name="android:background">@drawable/key_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/kb_key_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="Widget.Vaani.LangOption" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/vaani_surface_card</item>
        <item name="android:textColor">@color/vaani_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="Widget.Vaani.StatusChip" parent="Widget.AppCompat.TextView">
        <item name="android:background">@drawable/chip_bg</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>