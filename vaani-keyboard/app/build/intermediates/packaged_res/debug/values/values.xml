    <string name="perm_mic_denied_message">Microphone access was denied. Vaani needs this to convert your speech to text. You can enable it in Settings.</string>
    <string name="perm_mic_denied_title">Permission Required</string>
    <string name="perm_mic_disabled">Tap to Enable Voice Input</string>
    <string name="perm_mic_enabled">Voice Input: Enabled</string>
    <string name="perm_mic_rationale_message">Vaani needs microphone access to convert your voice into text. Your speech is processed entirely on your phone — nothing is sent online.</string>
    <string name="perm_mic_rationale_title">Microphone Access</string>
    <string name="perm_open_settings">Open Settings</string>
    <string name="settings_about_label">About Vaani</string>
    <string name="settings_about_text">Vaani converts your native language text and voice into grammatically correct English. Everything runs entirely on your device — no internet needed, no data leaves your phone.\n\nVersion 1.0.0</string>
    <string name="settings_lang_saved">Language saved</string>
    <string name="settings_language_label">Input Language</string>
    <string name="settings_title">Settings</string>
    <string name="setup_btn_back">Back</string>
    <string name="setup_btn_finish">Finish</string>
    <string name="setup_btn_next">Next</string>
    <string name="setup_enable_instructions">To use Vaani for typing:\n\n1. Open your phone\'s Settings\n2. Go to Language &amp; Input\n3. Select Keyboards / On-screen keyboard\n4. Enable "Vaani"\n5. Return here and tap Next</string>
    <string name="setup_enable_open_settings">Open Keyboard Settings</string>
    <string name="setup_enable_return_hint">Return to this screen after enabling</string>
    <string name="setup_enable_title">Enable Vaani Keyboard</string>
    <string name="setup_language_subtitle">Select the language you\'ll type in. Vaani will transliterate and translate it to English.</string>
    <string name="setup_language_title">Choose Your Input Language</string>
    <string name="setup_ready_tip">Try the voice input button on the keyboard</string>
    <string name="setup_ready_title">You\'re All Set!</string>
    <string name="setup_ready_tutorial">Type in Hindi, Marathi, or Hinglish\nVaani transliterates to Devanagari\nthen translates to English</string>
    <string name="setup_step_of">Step %1$d of %2$d</string>
    <string name="setup_switch_instructions">To make Vaani your main keyboard:\n\n1. Open your phone\'s Settings\n2. Go to Language &amp; Input\n3. Tap Default Keyboard\n4. Select "Vaani"\n5. Return here and tap Next</string>
    <string name="setup_switch_open_settings">Open Keyboard Settings</string>
    <string name="setup_switch_title">Set Vaani as Default Keyboard</string>
